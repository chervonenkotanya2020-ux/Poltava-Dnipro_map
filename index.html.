<!DOCTYPE html>
<html lang="uk">
<head>
    <meta charset="UTF-8">
    <title>TACTICAL_SYSTEM_V12_FINAL</title>
    <script src="https://www.gstatic.com/firebasejs/8.10.1/firebase-app.js"></script>
    <script src="https://www.gstatic.com/firebasejs/8.10.1/firebase-database.js"></script>
    <script src="https://unpkg.com/maplibre-gl@latest/dist/maplibre-gl.js"></script>
    <link href="https://unpkg.com/maplibre-gl@latest/dist/maplibre-gl.css" rel="stylesheet" />

    <style>
        :root { 
            --main: #ff0044; 
            --uav-filter: none; 
            --neon: #00f2ff; 
        }
        
        body { 
            margin: 0; 
            background: #000; 
            font-family: 'Orbitron', sans-serif; 
            overflow: hidden; 
            color: var(--neon); 
        }

        #map { 
            position: absolute; 
            top: 0; 
            bottom: 0; 
            width: 100%; 
            cursor: crosshair; 
        }

        /* Водяні знаки */
        .watermark {
            position: absolute;
            z-index: 50;
            color: rgba(255, 255, 255, 0.06); /* Дуже прозорий текст */
            font-size: 20px;
            font-weight: bold;
            pointer-events: none;
            user-select: none;
            text-transform: uppercase;
            white-space: nowrap;
        }
        /* Розташування знаків */
        .wm-1 { top: 15%; left: 10%; transform: rotate(-25deg); }
        .wm-2 { bottom: 20%; right: 10%; transform: rotate(-25deg); }
        .wm-3 { top: 50%; left: 40%; transform: rotate(-25deg); font-size: 22px; }

        .panel {
            position: absolute; 
            top: 20px; 
            left: 20px; 
            z-index: 100;
            background: rgba(10, 20, 30, 0.95); 
            border: 1px solid var(--main);
            border-radius: 12px; 
            padding: 15px; 
            width: 230px; 
            transition: 0.3s;
        }

        .panel.minimized { width: 50px; min-width: 50px; height: 50px; overflow: hidden; }
        .panel.minimized .hide-content { display: none; }

        .toggle-btn { 
            position: absolute; top: 5px; right: 5px; cursor: pointer; 
            background: none; border: 1px solid var(--neon); 
            color: var(--neon); font-size: 10px; 
        }

        .counter { font-size: 32px; font-weight: 900; color: var(--main); margin-bottom: 10px; }

        .btn { 
            width: 100%; padding: 10px; margin-top: 8px; cursor: pointer; 
            border: none; border-radius: 5px; font-weight: bold; 
            text-transform: uppercase; font-size: 10px; 
        }

        .btn-marker { background: #ffaa00; color: #000; }
        .btn-marker.active { background: #00ff44; box-shadow: 0 0 15px #00ff44; }

        input { 
            width: 100%; padding: 10px; background: #111; border: 1px solid #333;
            color: #fff; border-radius: 5px; box-sizing: border-box; 
        }

        .uav-img { 
            width: 40px; height: 40px;
            filter: var(--uav-filter) drop-shadow(0 0 8px var(--main)); 
            transition: 0.2s; 
        }
        
        .osint-label { font-size: 9px; opacity: 0.5; margin-top: 10px; display: block; }
    </style>
</head>
<body>

    <div class="watermark wm-1">@poltavatrivoga2026</div>
    <div class="watermark wm-2">@poltavatrivoga2026</div>
    <div class="watermark wm-3">@veselekamenskoe</div>

    <div class="panel" id="mainPanel">
        <button class="toggle-btn" onclick="document.getElementById('mainPanel').classList.toggle('minimized')">M</button>
        <div class="counter" id="cnt">00</div>
        
        <div class="hide-content">
            <input type="text" id="citySearch" placeholder="ПОШУК МІСТА">
            <button class="btn" style="background:var(--neon)" onclick="findCity()">ЗНАЙТИ</button>
            
            <button id="markerBtn" class="btn btn-marker" onclick="toggleMarkerMode()">🖌️ МАЛЮВАТИ ВЕКТОР</button>
            <button class="btn" style="background:transparent; border: 1px solid #ffaa00; color:#ffaa00;" onclick="db.ref('vectors').remove()">ПРИБРАТИ ВЕКТОРИ</button>
            <button class="btn" style="background:red; color:white;" onclick="clearAll()">ОЧИСТИТИ ВСЕ</button>
            
            <span class="osint-label">OSINT DATA ACTIVE</span>
            <div onclick="auth()" id="auth-status" style="font-size:8px; margin-top:10px; text-align:center; opacity:0.3; cursor:pointer;">[SECURE LOGIN]</div>
        </div>
    </div>

    <div id="map"></div>

    <script>
        const firebaseConfig = { databaseURL: "https://shmap-8c0fa-default-rtdb.firebaseio.com" };
        firebase.initializeApp(firebaseConfig);
        const db = firebase.database();

        let isAdmin = false, markerMode = false, lastUavId = null;
        const markers = {}, lineIds = [];

        const map = new maplibregl.Map({
            container: 'map',
            style: 'https://basemaps.cartocdn.com/gl/dark-matter-gl-style/style.json',
            center: [34.55, 49.58], // Полтава по дефолту
            zoom: 8
        });

        function auth() { 
            if(prompt("KEY:") === "1234") { 
                isAdmin = true; 
                document.getElementById('auth-status').innerText="[ADMIN ACTIVE]";
            } 
        }

        async function findCity() {
            const val = document.getElementById('citySearch').value;
            const r = await fetch(`https://nominatim.openstreetmap.org/search?format=json&q=${val}`);
            const d = await r.json();
            if(d[0]) map.flyTo({center: [parseFloat(d[0].lon), parseFloat(d[0].lat)], zoom: 9});
        }

        function toggleMarkerMode() {
            markerMode = !markerMode;
            document.getElementById('markerBtn').classList.toggle('active');
            document.getElementById('markerBtn').innerText = markerMode ? "КЛІКНІТЬ НА ЦІЛЬ" : "🖌️ МАЛЮВАТИ ВЕКТОР";
        }

        map.on('click', e => {
            if(!isAdmin) return;
            if(markerMode && lastUavId) {
                db.ref('v26_mobile/' + lastUavId).once('value', snap => {
                    const u = snap.val();
                    if(u) {
                        const brng = getBrng({lat: u.lat, lng: u.lng}, {lat: e.lngLat.lat, lng: e.lngLat.lng});
                        db.ref('vectors/' + lastUavId).set({ start: [u.lng, u.lat], end: [e.lngLat.lng, e.lngLat.lat] });
                        db.ref('v26_mobile/' + lastUavId).update({ brng: brng });
                    }
                });
                markerMode = false;
                document.getElementById('markerBtn').classList.remove('active');
            } else {
                const id = 'u-' + Date.now();
                lastUavId = id;
                db.ref('v26_mobile/' + id).set({ lat: e.lngLat.lat, lng: e.lngLat.lng, type: 'shahed', brng: 0 });
            }
        });

        db.ref('v26_mobile').on('value', snap => {
            const data = snap.val() || {};
            Object.keys(markers).forEach(id => { if(!data[id]) { markers[id].remove(); delete markers[id]; } });
            for(let id in data) {
                const t = data[id];
                if(!markers[id]) {
                    const el = document.createElement('div');
                    el.className = 'uav-marker';
                    el.innerHTML = `<img src="./icons/${t.type}.png" class="uav-img" style="transform: rotate(${t.brng || 0}deg)" onerror="this.src='https://cdn-icons-png.flaticon.com/512/2590/2590500.png'">`;
                    el.onclick = (ev) => { 
                        ev.stopPropagation(); 
                        lastUavId = id; 
                        if(isAdmin && !markerMode) {
                            db.ref('v26_mobile/'+id).remove();
                            db.ref('vectors/'+id).remove(); 
                        }
                    };
                    markers[id] = new maplibregl.Marker({element: el}).setLngLat([t.lng, t.lat]).addTo(map);
                } else {
                    markers[id].setLngLat([t.lng, t.lat]);
                    markers[id].getElement().querySelector('img').style.transform = `rotate(${t.brng || 0}deg)`;
                }
            }
            document.getElementById('cnt').innerText = Object.keys(data).length.toString().padStart(2, '0');
        });

        function getBrng(s, e) {
            const y = Math.sin((e.lng - s.lng) * Math.PI / 180) * Math.cos(e.lat * Math.PI / 180);
            const x = Math.cos(s.lat * Math.PI / 180) * Math.sin(e.lat * Math.PI / 180) - Math.sin(s.lat * Math.PI / 180) * Math.cos(e.lat * Math.PI / 180) * Math.cos((e.lng - s.lng) * Math.PI / 180);
            return (Math.atan2(y, x) * 180 / Math.PI + 360) % 360;
        }

        function clearAll() { 
            if(isAdmin) { 
                db.ref('v26_mobile').remove(); 
                db.ref('vectors').remove(); 
            } 
        }

        db.ref('vectors').on('value', snap => {
            const data = snap.val() || {};
            lineIds.forEach(id => { if(map.getLayer(id)) map.removeLayer(id); if(map.getSource(id)) map.removeSource(id); });
            lineIds.length = 0;
            for(let id in data) {
                const lId = 'line-' + id;
                map.addSource(lId, { 'type': 'geojson', 'data': { 'type': 'Feature', 'geometry': { 'type': 'LineString', 'coordinates': [data[id].start, data[id].end] } } });
                map.addLayer({ 'id': lId, 'type': 'line', 'source': lId, 'paint': { 'line-color': '#ff0044', 'line-width': 2, 'line-dasharray': [2, 1] } });
                lineIds.push(lId);
            }
        });

        map.on('zoom', () => {
            const s = Math.min(Math.max(map.getZoom() * 4, 12), 45);
            document.querySelectorAll('.uav-img').forEach(i => { i.style.width = s + 'px'; i.style.height = s + 'px'; });
        });
    </script>
</body>
</html>
